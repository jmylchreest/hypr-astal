{
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "paths": {
      "ags/*": [
        "node_modules/ags/*"
      ],
      "gi://*": [
        "node_modules/@girs/*"
      ]
    },
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020"
  },
  "exclude": [
    "node_modules",
    "dist"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}